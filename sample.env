# ==============================================================================
# sample.env - Environment Variables Template
# ==============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit your .env file to git - it contains sensitive credentials!
# 
# How to get these values:
# - API_ID & API_HASH: https://my.telegram.org/apps
# - BOT_TOKEN: Create bot with @BotFather on Telegram
# - LOGGER_ID: Create a private group, add bot, get chat ID
# - MONGO_DB_URI: MongoDB connection string (use MongoDB Atlas for free)
# - OWNER_ID: Your Telegram user ID (get from @userinfobot)
# - STRING_SESSION: Generate from @StringFatherBot (Pyrogram session)
# - COOKIE_URL: Optional - URL to YouTube cookies file for age-restricted videos
# ==============================================================================

API_ID=
API_HASH=
BOT_TOKEN=
LOGGER_ID=
MONGO_DB_URI=
OWNER_ID=
STRING_SESSION=
COOKIE_URL=
# - YTDLP_PROXY: Optional - proxy URL for yt-dlp (Webshare/Brightdata/Oxylabs)
#   Format: http://user:pass@host:port
YTDLP_PROXY=

# - POT_PROVIDER_URL: Optional - base URL of a running bgutil-ytdlp-pot-provider
#   server (e.g. http://YOUR_VPS_IP:4416). Helps bypass YouTube bot-checks
#   on datacenter IPs (Render/Lightsail). Leave empty to disable.
POT_PROVIDER_URL=

# ==============================================================================
# EXTERNAL DOWNLOAD API — ArtistBots (REQUIRED for playback)
# ==============================================================================
# This bot downloads audio/video ONLY through the ArtistBots API.
# There is NO fallback to yt-dlp/cookies — if the API fails (quota hit,
# downtime, bad key), playback for that track fails. Make sure at least
# one valid key is set.
#
# API_URL      : ArtistBots base URL for audio   (e.g. https://artistbots.onrender.com)
# VIDEO_API_URL: ArtistBots base URL for video    (usually the same host as API_URL)
# API_KEYS     : one or more ArtistBots keys, comma-separated, no spaces:
#                  API_KEYS=key1,key2,key3
#                Each key has its own 500/day quota on ArtistBots' side, so
#                N keys ≈ N × 500 requests/day. The bot rotates to the next
#                key on every single request (round-robin), regardless of
#                success or failure, to spread load evenly across all keys.
# API_KEY      : single-key fallback, only used if API_KEYS is left empty.
#
API_URL=https://artistbots.onrender.com
VIDEO_API_URL=https://artistbots.onrender.com
API_KEYS=key1,key2,key3
# API_KEY=


# Optional: Additional assistant sessions for handling multiple groups

# STRING_SESSION2=
# STRING_SESSION3=
# STRING_SESSION4=
# STRING_SESSION5=

# ==============================================================================
# FEATURE FLAGS (Optional)
# ==============================================================================

# AUTO_END: Automatically end stream when queue finishes (True/False)
# AUTO_END=False

# AUTO_LEAVE: Assistants auto-leave inactive groups every 30 min (True/False)
# AUTO_LEAVE=False

# THUMB_GEN: Generate custom thumbnails for now playing (True/False)
# THUMB_GEN=True

# VIDEO_PLAY: Enable /vplay commands for streaming video in VC (True/False)
# VIDEO_PLAY=True

# VIDEO_MAX_HEIGHT: Max resolution (in pixels) for /vplay downloads (e.g. 720, 1080)
# VIDEO_MAX_HEIGHT=1080

# ==============================================================================
# MODERATION (Optional)
# ==============================================================================

# EXCLUDED_USERNAMES: Space-separated list of usernames to exclude from admin mentions
# EXCLUDED_USERNAMES=User1 User2 User3
